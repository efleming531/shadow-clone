DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
JWT_SECRET="replace-with-a-long-random-string"
PORT=4000
NODE_ENV=development

# Optional: CORS origin (defaults to http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Railway-assigned public URL — used in domain connection instructions
# so users know what CNAME value to enter at their registrar.
# Example: shadow-clone-production.up.railway.app
RAILWAY_PUBLIC_URL=

# Optional: Anthropic API key for AI-powered roofing quote analysis
ANTHROPIC_API_KEY=
